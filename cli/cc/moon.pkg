import {
  "moonbitlang/core/env",
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/x/sys",
  "moonbitlang/async",
  "moonbitlang/async/process",
  "moonbitlang/async/pipe" @pipe,
}

supported_targets = "+native"

options(
  "bin-name": "cc",
  "bin-target": "native",
  "is-main": true,
  "native-stub": [ "target_stub.c" ],
)
