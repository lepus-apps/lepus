import {
  "lepus-apps/lepus",
  "lepus-apps/lepus/plugins/lepus_plugin_log",
  "lepus-apps/lepus/plugins/lepus_plugin_support",
}

supported_targets = "+native"

options(
  "is-main": true,
  link: {
    "native": {
      "cc-link-flags": "-Lwebview/lib -lwebview -Wl,-rpath,@loader_path/../../../../../../webview/lib",
    },
  },
  targets: { "main.mbt": [ "native" ] },
)
