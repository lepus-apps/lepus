import {
  "lepus-apps/lepus/packages/lepus",
  "lepus-apps/lepus/packages/lepus_plugin_http",
  "lepus-apps/lepus/packages/lepus_plugin_support",
}

supported_targets = "+native"

options(
  "is-main": true,
  link: {
    "native": {
      "cc-link-flags": "-Lpackages/lepus_runtime_webview/lib -lwebview -Wl,-rpath,@loader_path/../../../../../../packages/lepus_runtime_webview/lib",
    },
  },
  targets: { "main.mbt": [ "native" ] },
)
